# Token ve Veritabanı Ayarları
TOKEN=your_bot_token_here
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/premium-bot

# Bot Ayarları
PREFIX=-/
BOT_ID=your_bot_id

# Sunucu Ayarları
MAIN_SERVER_ID=your_server_id
MOD_CHANNEL_ID=your_mod_channel_id
LOG_CHANNEL_ID=your_log_channel_id
WELCOME_CHANNEL_ID=your_welcome_channel_id
BAN_LOG_CHANNEL_ID=your_ban_log_channel_id
REGISTRATION_CHANNEL_ID=your_registration_channel_id

# Admin IDs
ADMIN_IDS=admin_id_1,admin_id_2,admin_id_3
